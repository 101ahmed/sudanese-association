# انسخ هذا الملف إلى `.env.prod.local` على الخادم وعدّل القيم (لا ترفع `.env.prod.local` إلى Git).
# Copy to `.env.prod.local` on the server and edit (never commit `.env.prod.local`).
#
# بعد `composer install --no-dev --optimize-autoloader` على الخادم:
#   composer run prod:post-install
# (هجرات + كاش prod + assets)

###> secrets & database ###
#APP_SECRET=ضع_هنا_مخرجات_php_-r_echo_bin2hex_random_bytes_16
# HOST: على الاستضافة المشتركة غالباً ليس 127.0.0.1 — انسخ «nom d’hôte / hostname» من لوحة MySQL (IONOS، OVH، إلخ).
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
###< secrets & database ###

###> اسم الموقع على الإنترنت ###
# الاسم النهائي: https://sd-rennes.fr (لا تضف / في نهاية القيمة هنا)
DEFAULT_URI=https://sd-rennes.fr
###< اسم الموقع على الإنترنت ###

