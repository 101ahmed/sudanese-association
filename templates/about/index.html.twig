{% extends 'base.html.twig' %}

{% block title %}من نحن{% endblock %}

{% block body %}

    <section class="bg-dark text-white text-center p-5">

        <h1>
            من نحن
        </h1>

        <p class="lead">
            رابطة الجالية السودانية برين
        </p>

    </section>


    <section class="container mt-5">

        <div class="row">

            <div class="col-md-6">

                <h2>الرؤية</h2>

                <p>

                    أن تكون رابطة الجالية السودانية في Rennes
                    منصة تجمع أبناء الجالية وتدعم التعليم
                    والأنشطة الثقافية والاجتماعية.

                </p>

            </div>


            <div class="col-md-6">

                <h2>الرسالة</h2>

                <p>

                    تعزيز التواصل بين أبناء الجالية السودانية
                    وتوفير بيئة تعليمية وثقافية تساعد
                    على تنمية الأجيال القادمة.

                </p>

            </div>

        </div>

    </section>


    <section class="container mt-5">

        <h2 class="text-center mb-4">
            أهداف الرابطة
        </h2>

        <ul class="list-group">

            <li class="list-group-item">
                تعزيز الروابط بين أبناء الجالية السودانية
            </li>

            <li class="list-group-item">
                دعم التعليم والبرامج الأكاديمية
            </li>

            <li class="list-group-item">
                تنظيم الأنشطة الثقافية والاجتماعية
            </li>

            <li class="list-group-item">
                خدمة المجتمع السوداني في Rennes
            </li>

        </ul>

    </section>

{% endblock %}
