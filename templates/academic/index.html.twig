{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-5">

        <h2 class="mb-4 text-center">📚 الأمانة الأكاديمية</h2>

        <!-- Navigation -->
        <div class="mb-4 text-center">
            <a href="/admin/academic" class="btn btn-dark mx-1">🏠 Dashboard</a>
            <a href="/admin/students" class="btn btn-primary mx-1">👨‍🎓 الطلاب</a>
            <a href="/admin/guardians" class="btn btn-info mx-1">👨‍👩‍👧 أولياء الأمور</a>
            <a href="/admin/attendance/create" class="btn btn-success mx-1">📅 الحضور</a>
        </div>

        <!-- Stats -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card p-4 text-center shadow">
                    <h5>عدد الطلاب</h5>
                    <h2 class="text-primary">{{ studentsCount }}</h2>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-4 text-center shadow">
                    <h5>عدد الحضور اليوم</h5>
                    <h2 class="text-success">{{ attendanceCount }}</h2>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card p-3 shadow">
            <h4>آخر الطلاب</h4>

            <table class="table table-bordered text-center">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>الاسم</th>
                    <th>المستوى</th>
                    <th>ولي الأمر</th>
                </tr>
                </thead>

                <tbody>
                {% for student in students %}
                    <tr>
                        <td>{{ student.id }}</td>
                        <td>{{ student.name }}</td>
                        <td>{{ student.level }}</td>
                        <td>{{ student.guardian.name }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">لا يوجد طلاب</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </div>

{% endblock %}
