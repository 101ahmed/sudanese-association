{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-5">

        <h2 class="text-center mb-4">📋 قائمة الطلاب</h2>

        <table class="table table-bordered text-center">

            <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>الاسم</th>
                <th>المستوى</th>
                <th>ولي الأمر</th>
            </tr>
            </thead>

            <tbody>
            {% for student in students %}
                <tr>
                    <td>{{ student.id }}</td>
                    <td>{{ student.name }}</td>
                    <td>{{ student.level }}</td>
                    <td>{{ student.guardian.name }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">لا يوجد طلاب</td>
                </tr>
            {% endfor %}
            </tbody>

        </table>

        <a href="/admin/add-student" class="btn btn-primary">
            ➕ إضافة طالب
        </a>

    </div>

{% endblock %}
