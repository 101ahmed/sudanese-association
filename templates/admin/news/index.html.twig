{% extends 'base.html.twig' %}

{% block title %}الأخبار{% endblock %}

{% block body %}

    <div class="container mt-5">

        <h2 class="text-center mb-4">📰 الأخبار</h2>

        <!-- 🔍 Search -->
        <form method="get" class="mb-3">
            <input type="text" name="q" class="form-control" placeholder="بحث...">
        </form>

        <!-- ➕ Add -->
        <a href="{{ path('news_create') }}" class="btn btn-primary mb-3">
            ➕ إضافة خبر
        </a>

        {% for item in news %}
            <div class="card mb-3 shadow">
                <div class="card-body">

                    {% if item.image %}
                        <img src="/uploads/{{ item.image }}" width="100%">
                    {% endif %}

                    <h4>{{ item.title }}</h4>
                    <p>{{ item.content }}</p>

                    <a href="{{ path('news_edit', {id: item.id}) }}" class="btn btn-warning">✏️</a>
                    <a href="{{ path('news_delete', {id: item.id}) }}" class="btn btn-danger">🗑</a>

                </div>
            </div>
        {% else %}
            <p class="text-center">لا توجد أخبار</p>
        {% endfor %}

    </div>

{% endblock %}
