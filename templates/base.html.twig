<!DOCTYPE html>
{% trans_default_domain 'messages' %}
<html lang="{{ app.request.locale }}" dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'app.title'|trans }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="app-body">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark app-navbar sticky-top">
    <div class="container">

        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="{{ asset('image/photo01.jpg') }}"
                 alt="Logo"
                 width="50"
                 height="50"
                 class="{{ app.request.locale == 'ar' ? 'ms-2' : 'me-2' }}">
            <span></span>
        </a>

        <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="menu">
            <ul class="navbar-nav {{ app.request.locale == 'ar' ? 'ms-auto' : 'me-auto' }}">

                <li class="nav-item">
                    <a class="nav-link" href="/">{{ 'nav.home'|trans }}</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/about">{{ 'nav.about'|trans }}</a>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        {{ 'nav.committee'|trans }}
                    </a>

                    <ul class="dropdown-menu {{ app.request.locale == 'ar' ? 'text-end' : 'text-start' }}">
                        <li>
                            <a class="dropdown-item" href="/committee/academic">{{ 'nav.committee_chair'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/academic">{{ 'nav.committee_general'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/admin/academic">{{ 'nav.committee_academic'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/academic">{{ 'nav.committee_social'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/academic">{{ 'nav.committee_communication'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/academic">{{ 'nav.committee_women_children'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/statistics">{{ 'nav.committee_statistics'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/events">{{ 'nav.committee_external'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/media">{{ 'nav.committee_media'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/members">{{ 'nav.committee_shura'|trans }}</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/committee/members">{{ 'nav.committee_fathers'|trans }}</a>
                        </li>
                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('committee_events') }}">{{ 'nav.events'|trans }}</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('public_news_list') }}">{{ 'nav.news'|trans }}</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('contact') }}">
                        {{ 'nav.contact'|trans }}
                    </a>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        🌐 {{ app.request.locale|upper }}
                    </a>
                    <ul class="dropdown-menu {{ app.request.locale == 'ar' ? 'text-end' : 'text-start' }}">
                        <li><a class="dropdown-item" href="{{ path('set_locale', {locale: 'ar'}) }}">العربية</a></li>
                        <li><a class="dropdown-item" href="{{ path('set_locale', {locale: 'en'}) }}">English</a></li>
                        <li><a class="dropdown-item" href="{{ path('set_locale', {locale: 'fr'}) }}">Français</a></li>
                    </ul>
                </li>

            </ul>
        </div>

    </div>
</nav>

{% block body %}{% endblock %}

<footer class="bg-dark text-white text-center p-4 mt-5 app-footer">
    {{ 'footer.title'|trans }}
</footer>

</body>
</html>
