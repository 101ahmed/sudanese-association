{% extends 'base.html.twig' %}

{% block title %}{{ 'contact.title'|trans }}{% endblock %}

{% block body %}
    <div class="container mt-5">
        {% set successMessages = app.flashes('success') %}
        {% if successMessages is not empty %}
            <div class="row">
                <div class="col-12">
                    {% for message in successMessages %}
                        <div class="alert alert-success text-center contact-alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <div class="row g-4">
            
            <!-- 📩 FORM -->
            <div class="col-md-6">

                <div class="card shadow-sm border-0 contact-panel">
                    <div class="card-body p-4 p-lg-5">
                        <h2 class="mb-4">📩 {{ 'contact.title'|trans }}</h2>

                        <form method="post" class="contact-form">
                            <div class="mb-3">
                                <label class="form-label">{{ 'contact.name'|trans }}</label>
                                <input type="text" class="form-control" name="name" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">{{ 'contact.email'|trans }}</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">{{ 'contact.subject'|trans }}</label>
                                <input type="text" class="form-control" name="subject">
                            </div>

                            <div class="mb-4">
                                <label class="form-label">{{ 'contact.message'|trans }}</label>
                                <textarea class="form-control" rows="5" name="message" required></textarea>
                            </div>

                            <button class="btn btn-success w-100">{{ 'contact.send'|trans }}</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- 📍 INFO -->
            <div class="col-md-6">
                <div class="card p-4 shadow-sm border-0 contact-panel">
                    <h2 class="mb-4">📍 {{ 'contact.info_title'|trans }}</h2>

                    <p><strong>📍 {{ 'contact.location_label'|trans }}:</strong> Rennes - France</p>
                    <p><strong>📧 {{ 'contact.email_short'|trans }}:</strong> association.sad.fra@gmail.com</p>
                    <p class="mb-0"><strong>📞 {{ 'contact.phone_label'|trans }}:</strong> 07 83 15 52 47</p>
                </div>

                <!-- 🗺 MAP -->
                <div class="mt-4 card border-0 shadow-sm overflow-hidden">
                    <iframe
                        src="https://www.google.com/maps?q=Rennes&output=embed"
                        width="100%"
                        height="280"
                        style="border:0;">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
