{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-5 page-wrap">

        <h2 class="text-center mb-5">📅 {{ 'events.title'|trans }}</h2>

        {# لا يوجد حالياً route لإنشاء الفعاليات في admin في هذا المشروع #}

        <div class="row g-4">

            {% for event in events %}
                <div class="col-md-4">
                    <div class="card shadow-sm p-3 h-100">

                        <h5>{{ 'events.item'|trans }} #{{ event.id }}</h5>
                        <p class="text-muted mb-0">{{ 'events.detail_unavailable'|trans }}</p>

                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="empty-state ui-fade-in">
                        <div class="empty-state-icon">📅</div>
                        {{ 'events.none'|trans }}
                    </div>
                </div>
            {% endfor %}

        </div>

    </div>

{% endblock %}
