{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.home'|trans }}{% endblock %}

{% block body %}

    <section class="site-hero" id="home">
        <div class="hero-copy">
            <span class="hero-tag">{{ 'home.hero.kicker'|trans }}</span>
            <h1>{{ 'home.hero.title'|trans }}</h1>
            <p>{{ 'home.hero.subtitle'|trans }}</p>
            <div class="hero-actions">
                <a href="{{ path('about') }}" class="site-btn">{{ 'about.title'|trans }}</a>
                <a href="{{ path('contact') }}" class="site-btn site-btn-secondary">{{ 'contact.title'|trans }}</a>
            </div>
        </div>

        <div class="hero-panel">
            <div class="hero-stat">
                <strong>{{ studentsCount }}</strong>
                <span>{{ 'home.stats_students'|trans }} — {{ 'home.hero.stat_community_desc'|trans }}</span>
            </div>
            <div class="hero-stat">
                <strong>{{ eventsCount }}</strong>
                <span>{{ 'home.stats_events'|trans }} — {{ 'home.hero.stat_programs_desc'|trans }}</span>
            </div>
            <div class="hero-stat">
                <strong>{{ newsCount }}</strong>
                <span>{{ 'home.stats_news'|trans }} — {{ 'home.hero.stat_news_desc'|trans }}</span>
            </div>
        </div>
    </section>

    <section class="site-landing-section" id="programs" aria-labelledby="programs-heading">
        <span class="site-section-kicker" id="programs-kicker">{{ 'home.programs.subheading'|trans }}</span>
        <h2 class="site-section-title" id="programs-heading">{{ 'home.programs.heading'|trans }}</h2>

        <div class="site-card-grid">
            {% for i in 1..6 %}
                <article class="site-info-card">
                    <span class="site-card-badge">0{{ i }}</span>
                    <h4>{{ ('home.programs.item' ~ i ~ '_title')|trans }}</h4>
                    <p>{{ ('home.programs.item' ~ i ~ '_text')|trans }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="site-landing-section site-landing-muted" id="site-sections">
        <h2 class="text-center mb-4">{{ 'home.sections'|trans }}</h2>

        <div class="row text-center g-4">
            <div class="col-md-3">
                <a href="{{ path('committee_academic') }}" class="bbc-card-link">
                    <div class="card shadow-sm bbc-info-card h-100">
                        <div class="card-body">
                            <h5>{{ 'nav.committee_academic'|trans }}</h5>
                            <p class="mb-0">{{ 'home.stats_students'|trans }}: {{ studentsCount }}</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3">
                <a href="{{ path('committee_statistics') }}" class="bbc-card-link">
                    <div class="card shadow-sm bbc-info-card h-100">
                        <div class="card-body">
                            <h5>{{ 'nav.committee_statistics'|trans }}</h5>
                            <p class="mb-0">{{ 'home.stats_attendance'|trans }}: {{ attendanceCount }}</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3">
                <a href="{{ path('committee_events') }}" class="bbc-card-link">
                    <div class="card shadow-sm bbc-info-card h-100">
                        <div class="card-body">
                            <h5>{{ 'nav.events'|trans }}</h5>
                            <p class="mb-0">{{ 'home.stats_events'|trans }}: {{ eventsCount }}</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3">
                <a href="{{ path('public_news_list') }}" class="bbc-card-link">
                    <div class="card shadow-sm bbc-info-card h-100">
                        <div class="card-body">
                            <h5>{{ 'nav.news'|trans }}</h5>
                            <p class="mb-0">{{ 'home.stats_news'|trans }}: {{ (featured ? 1 : 0) + (news|length) }}</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <section class="site-landing-section" id="about" aria-labelledby="about-heading">
        <div class="site-split-card">
            <div class="site-split-panel site-accent-panel">
                <span class="site-card-badge">SR</span>
                <h2>{{ 'home.about_split.card_title'|trans }}</h2>
                <p>{{ 'home.about_split.card_text'|trans }}</p>
            </div>

            <div class="site-split-panel">
                <span class="site-section-kicker">{{ 'home.about_split.subheading'|trans }}</span>
                <h2 class="site-section-title" id="about-heading">{{ 'home.about_split.heading'|trans }}</h2>
                <p>{{ 'home.about_split.text1'|trans }}</p>
                <p>{{ 'home.about_split.text2'|trans }}</p>
                <div class="site-mini-list">
                    <span>{{ 'home.about_split.feature1'|trans }}</span>
                    <span>{{ 'home.about_split.feature2'|trans }}</span>
                    <span>{{ 'home.about_split.feature3'|trans }}</span>
                </div>
                <a href="{{ path('about') }}" class="site-read-more">{{ 'home.about_split.read_more'|trans }} →</a>
            </div>
        </div>
    </section>

    {% set newsTotal = (featured ? 1 : 0) + (news|length) %}
    <section class="site-landing-section site-landing-muted text-center" id="stats" aria-labelledby="stats-heading">
        <h2 class="mb-4" id="stats-heading">{{ 'home.stats_title'|trans }}</h2>

        <div class="row g-4 justify-content-center">
            <div class="col-12 col-md-3">
                <div class="bbc-stats-card">
                    <h3 class="mb-1">{{ studentsCount }}</h3>
                    <p class="mb-0">{{ 'home.stats_students_singular'|trans }}</p>
                </div>
            </div>

            <div class="col-12 col-md-3">
                <div class="bbc-stats-card">
                    <h3 class="mb-1">{{ guardiansCount }}</h3>
                    <p class="mb-0">{{ 'home.stats_guardians_singular'|trans }}</p>
                </div>
            </div>

            <div class="col-12 col-md-3">
                <div class="bbc-stats-card">
                    <h3 class="mb-1">{{ attendanceCount }}</h3>
                    <p class="mb-0">{{ 'home.stats_attendance_singular'|trans }}</p>
                </div>
            </div>

            <div class="col-12 col-md-3">
                <div class="bbc-stats-card">
                    <h3 class="mb-1">{{ newsTotal }}</h3>
                    <p class="mb-0">{{ 'home.stats_news_singular'|trans }}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="site-landing-section" id="goals" aria-labelledby="goals-heading">
        <span class="site-section-kicker">{{ 'home.goals.subheading'|trans }}</span>
        <h2 class="site-section-title" id="goals-heading">{{ 'home.goals.heading'|trans }}</h2>

        <div class="site-card-grid">
            {% for i in 1..6 %}
                <article class="site-info-card">
                    <span class="site-card-badge">0{{ i }}</span>
                    <h4>{{ ('home.goals.item' ~ i ~ '_title')|trans }}</h4>
                    <p>{{ ('home.goals.item' ~ i ~ '_text')|trans }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="site-landing-section site-landing-muted" id="reviews" aria-labelledby="reviews-heading">
        <span class="site-section-kicker">{{ 'home.reviews.subheading'|trans }}</span>
        <h2 class="site-section-title" id="reviews-heading">{{ 'home.reviews.heading'|trans }}</h2>

        <div class="site-card-grid site-reviews-grid">
            <article class="site-review-card">
                <div class="site-rating" aria-hidden="true">★★★★★</div>
                <h4>{{ 'home.reviews.r1_name'|trans }}</h4>
                <p>{{ 'home.reviews.r1_text'|trans }}</p>
            </article>
            <article class="site-review-card">
                <div class="site-rating" aria-hidden="true">★★★★★</div>
                <h4>{{ 'home.reviews.r2_name'|trans }}</h4>
                <p>{{ 'home.reviews.r2_text'|trans }}</p>
            </article>
            <article class="site-review-card">
                <div class="site-rating" aria-hidden="true">★★★★☆</div>
                <h4>{{ 'home.reviews.r3_name'|trans }}</h4>
                <p>{{ 'home.reviews.r3_text'|trans }}</p>
            </article>
        </div>
    </section>

    <section class="container mt-5 bbc-news" id="news">

        <div class="bbc-news-header d-flex justify-content-between align-items-center mb-4">
            <div class="bbc-news-title-wrap">
                <h2 class="bbc-news-title mb-0">📰 {{ 'news.title'|trans }}</h2>
                <span class="bbc-news-subtitle">{{ 'home.news_subtitle'|trans }}</span>
            </div>

            <a href="{{ path('public_news_list') }}" class="btn btn-outline-primary">{{ 'home.news_show_all'|trans }}</a>
        </div>

        <div class="row g-4 bbc-news-top align-items-stretch">

            <div class="col-lg-7">
                {% if featured %}
                    <article class="bbc-featured-card h-100">
                        <a href="{{ path('public_news_show', {id: featured.id}) }}" class="bbc-link">

                            <div class="bbc-featured-media">
                                {% if featured.image %}
                                    <img src="/uploads/{{ featured.image }}"
                                         alt="{{ featured.title }}"
                                         class="bbc-featured-img">
                                {% else %}
                                    <img src="https://picsum.photos/900/500"
                                         alt="{{ featured.title }}"
                                         class="bbc-featured-img">
                                {% endif %}

                                <span class="bbc-featured-badge">{{ 'home.news_featured_badge'|trans }}</span>
                            </div>

                            <div class="bbc-featured-content">
                                <div class="bbc-meta">
                                    {{ featured.createdAt ? featured.createdAt|date('Y-m-d') : '' }}
                                </div>
                                <h3 class="bbc-featured-title">{{ featured.title }}</h3>
                                <p class="bbc-featured-excerpt">
                                    {{ featured.content|slice(0,180) }}...
                                </p>
                            </div>

                        </a>
                    </article>
                {% else %}
                    <div class="empty-state ui-fade-in">
                        <div class="empty-state-icon">🗞️</div>
                        <p class="mb-0">{{ 'home.news_none_featured'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            <div class="col-lg-5">
                <div class="bbc-side-list h-100">
                    <div class="bbc-side-title">{{ 'home.news_quick_picks'|trans }}</div>

                    {% set rightNews = news|slice(0,3) %}
                    {% for item in rightNews %}
                        <a href="{{ path('public_news_show', {id: item.id}) }}" class="bbc-side-item">
                            <div class="bbc-side-thumb">
                                {% if item.image %}
                                    <img src="/uploads/{{ item.image }}" alt="{{ item.title }}">
                                {% else %}
                                    <img src="https://picsum.photos/220/140" alt="{{ item.title }}">
                                {% endif %}
                            </div>
                            <div class="bbc-side-body">
                                <div class="bbc-meta small">
                                    {{ item.createdAt ? item.createdAt|date('Y-m-d') : '' }}
                                </div>
                                <div class="bbc-side-card-title">{{ item.title }}</div>
                            </div>
                        </a>
                    {% else %}
                        <div class="empty-state ui-fade-in">
                            <div class="empty-state-icon">ℹ️</div>
                            <p class="mb-0">{{ 'home.news_none_additional'|trans }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>

        <div class="bbc-news-grid row g-4 mt-2">
            {% set gridNews = news|slice(3) %}
            {% for item in gridNews %}
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm bbc-news-card">

                        {% if item.image %}
                            <img src="/uploads/{{ item.image }}" class="bbc-news-img" alt="{{ item.title }}">
                        {% else %}
                            <img src="https://picsum.photos/400/200" class="bbc-news-img" alt="{{ item.title }}">
                        {% endif %}

                        <div class="card-body bbc-news-body">
                            <h5 class="card-title bbc-news-card-title">{{ item.title }}</h5>
                            <div class="bbc-meta small">
                                {{ item.createdAt ? item.createdAt|date('Y-m-d') : '' }}
                            </div>
                            <p class="bbc-news-excerpt">
                                {{ item.content|slice(0,120) }}...
                            </p>
                        </div>

                        <div class="card-footer bg-white border-0">
                            <a href="{{ path('public_news_show', {id: item.id}) }}" class="btn btn-primary w-100">
                                {{ 'home.news_read_more'|trans }} →
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="empty-state ui-fade-in">
                        <div class="empty-state-icon">📰</div>
                        <p class="mb-0">{{ 'news.no_news'|trans }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>

    </section>

    <section class="site-landing-section" id="gallery">
        <h2 class="text-center mb-4">{{ 'home.gallery_title'|trans }}</h2>

        {% if galleryImages is defined and galleryImages|length > 0 %}
            <div class="row g-3 bbc-gallery">
                {% for img in galleryImages %}
                    <div class="col-md-3">
                        <img src="/uploads/{{ img }}"
                             class="img-fluid rounded bbc-gallery-img"
                             alt="">
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state ui-fade-in">
                <div class="empty-state-icon">🖼️</div>
                <p class="mb-0">{{ 'home.gallery_none'|trans }}</p>
            </div>
        {% endif %}
    </section>

    <section class="site-landing-section site-landing-muted" id="contact" aria-labelledby="contact-heading">
        <span class="site-section-kicker">{{ 'home.contact_preview.subheading'|trans }}</span>
        <h2 class="site-section-title" id="contact-heading">{{ 'home.contact_preview.heading'|trans }}</h2>

        <div class="site-contact-preview">
            <div class="site-contact-info-panel">
                <span class="site-contact-chip">{{ 'home.contact_preview.lead_title'|trans }}</span>
                <p class="site-contact-lead">{{ 'home.contact_preview.lead_text'|trans }}</p>

                <div class="site-contact-cards">
                    <article class="site-contact-mini">
                        <span class="label">{{ 'home.contact_preview.phone_title'|trans }}</span>
                        <a href="tel:+330000000000" class="value">{{ 'home.contact_preview.phone_value'|trans }}</a>
                    </article>
                    <article class="site-contact-mini">
                        <span class="label">{{ 'home.contact_preview.email_title'|trans }}</span>
                        <a href="mailto:info@sudanrennes.org" class="value">{{ 'home.contact_preview.email_value'|trans }}</a>
                    </article>
                    <article class="site-contact-mini">
                        <span class="label">{{ 'home.contact_preview.location_title'|trans }}</span>
                        <span class="value">{{ 'home.contact_preview.location_value'|trans }}</span>
                    </article>
                </div>
            </div>

            <div class="site-contact-cta-panel">
                <p>{{ 'home.contact_text'|trans }}</p>
                <a href="{{ path('contact') }}" class="site-btn">{{ 'home.contact_preview.form_cta'|trans }}</a>
            </div>
        </div>
    </section>

{% endblock %}
