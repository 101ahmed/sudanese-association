{% extends 'base.html.twig' %}

{% block title %}الرئيسية{% endblock %}

{% block body %}

    <!-- HERO SECTION -->

    <section class="bg-success text-white text-center p-5">

        <div class="container">

            <h1 class="display-4">
                رابطة الجالية السودانية برين
            </h1>

            <p class="lead mt-3">
                منصة لخدمة أبناء الجالية وتنظيم التعليم والأنشطة الثقافية والاجتماعية
            </p>

            <div class="mt-4">

                <a href="#" class="btn btn-light btn-lg me-3">
                    تسجيل طالب
                </a>

                <a href="#" class="btn btn-outline-light btn-lg">
                    تعرف علينا
                </a>

            </div>

        </div>

    </section>


    <!-- ABOUT -->

    <section class="container mt-5 text-center">

        <h2 class="mb-4">من نحن</h2>

        <p class="lead">

            تسعى رابطة الجالية السودانية في مدينة Rennes إلى تعزيز الروابط
            بين أبناء الجالية، ودعم التعليم والأنشطة الثقافية والاجتماعية،
            وتوفير بيئة تعليمية متميزة لأبناء الجالية.

        </p>

    </section>


    <!-- MAIN SECTIONS -->

    <section class="container mt-5">

        <h2 class="text-center mb-5">أقسام الموقع</h2>

        <div class="row text-center g-4">

            <div class="col-md-3">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">
                            الأمانة الأكاديمية
                        </h5>

                        <p class="card-text">
                            إدارة البرامج التعليمية ومتابعة الطلاب
                        </p>

                    </div>

                </div>

            </div>


            <div class="col-md-3">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">
                            أمانة الإحصاء
                        </h5>

                        <p class="card-text">
                            تحليل البيانات وإعداد التقارير
                        </p>

                    </div>

                </div>

            </div>


            <div class="col-md-3">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">
                            الفعاليات
                        </h5>

                        <p class="card-text">
                            تنظيم الأنشطة الثقافية والاجتماعية
                        </p>

                    </div>

                </div>

            </div>


            <div class="col-md-3">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">
                            الأخبار
                        </h5>

                        <p class="card-text">
                            آخر أخبار الرابطة
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- STATISTICS -->

    <section class="bg-light mt-5 p-5">

        <div class="container text-center">

            <h2 class="mb-5">
                إحصائيات الرابطة
            </h2>

            <div class="row">

                <div class="col-md-3">

                    <h3>120</h3>

                    <p>طالب</p>

                </div>


                <div class="col-md-3">

                    <h3>15</h3>

                    <p>معلم</p>

                </div>


                <div class="col-md-3">

                    <h3>40</h3>

                    <p>متطوع</p>

                </div>


                <div class="col-md-3">

                    <h3>25</h3>

                    <p>فعالية</p>

                </div>

            </div>

        </div>

    </section>


    <!-- NEWS -->

    <section class="container mt-5">

        <h2 class="text-center mb-5">
            آخر الأخبار
        </h2>

        <div class="row g-4">


            <div class="col-md-4">

                <div class="card">

                    <img src="https://picsum.photos/400/200" class="card-img-top">

                    <div class="card-body">

                        <h5 class="card-title">
                            افتتاح العام الدراسي
                        </h5>

                        <p class="card-text">
                            تم افتتاح العام الدراسي الجديد بحضور أعضاء الرابطة.
                        </p>

                    </div>

                </div>

            </div>


            <div class="col-md-4">

                <div class="card">

                    <img src="https://picsum.photos/401/200" class="card-img-top">

                    <div class="card-body">

                        <h5 class="card-title">
                            فعالية ثقافية
                        </h5>

                        <p class="card-text">
                            نظمت الرابطة فعالية ثقافية لتعزيز التواصل بين أبناء الجالية.
                        </p>

                    </div>

                </div>

            </div>


            <div class="col-md-4">

                <div class="card">

                    <img src="https://picsum.photos/402/200" class="card-img-top">

                    <div class="card-body">

                        <h5 class="card-title">
                            برنامج دعم الطلاب
                        </h5>

                        <p class="card-text">
                            إطلاق برنامج لدعم الطلاب في التحصيل الدراسي.
                        </p>

                    </div>

                </div>

            </div>


        </div>

    </section>


    <!-- GALLERY -->

    <section class="container mt-5">

        <h2 class="text-center mb-5">
            معرض الصور
        </h2>

        <div class="row g-3">

            <div class="col-md-3">
                <img src="https://picsum.photos/300/200" class="img-fluid rounded">
            </div>

            <div class="col-md-3">
                <img src="https://picsum.photos/301/200" class="img-fluid rounded">
            </div>

            <div class="col-md-3">
                <img src="https://picsum.photos/302/200" class="img-fluid rounded">
            </div>

            <div class="col-md-3">
                <img src="https://picsum.photos/303/200" class="img-fluid rounded">
            </div>

        </div>

    </section>


    <!-- CONTACT -->

    <section class="bg-light mt-5 p-5">

        <div class="container">

            <h2 class="text-center mb-5">
                تواصل معنا
            </h2>

            <div class="row justify-content-center">

                <div class="col-md-6">

                    <form>

                        <div class="mb-3">

                            <label class="form-label">
                                الاسم
                            </label>

                            <input type="text" class="form-control">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                البريد الإلكتروني
                            </label>

                            <input type="email" class="form-control">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                الرسالة
                            </label>

                            <textarea class="form-control" rows="4"></textarea>

                        </div>

                        <button class="btn btn-success w-100">
                            إرسال
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </section>


{% endblock %}
