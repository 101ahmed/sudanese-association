{% extends 'base.html.twig' %}

{% block body %}

    <div class="container mt-5">

        <h1 class="text-center mb-5">الأخبار</h1>

        <div class="row">

            {% for article in news %}

                <div class="col-md-4">

                    <div class="card mb-4">

                        <img src="{{ article.image }}" class="card-img-top">

                        <div class="card-body">

                            <h5>{{ article.title }}</h5>

                            <p>{{ article.content|slice(0,100) }}...</p>

                            <a href="/admin/news/{{ article.id }}/edit" class="btn btn-warning btn-sm">
                                تعديل
                            </a>

                            <a href="/admin/news/{{ article.id }}/delete" class="btn btn-danger btn-sm">
                                حذف
                            </a>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

{% endblock %}
