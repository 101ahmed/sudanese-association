<h2 style="text-align:center;">📋 تقرير الطلاب</h2>

<table border="1" width="100%" cellspacing="0" cellpadding="5">
    <thead>
    <tr>
        <th>#</th>
        <th>الاسم</th>
        <th>المستوى</th>
        <th>ولي الأمر</th>
    </tr>
    </thead>
    <tbody>
    {% for student in students %}
        <tr>
            <td>{{ student.id }}</td>
            <td>{{ student.name }}</td>
            <td>{{ student.level }}</td>
            <td>{{ student.guardian.name }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
