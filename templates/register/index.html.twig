{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register_title'|trans }}{% endblock %}

{% block body %}
    <div class="container page-wrap">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="page-card">
                    <h1 class="text-center mb-4">{{ 'auth.register_h1'|trans }}</h1>

                    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.email, 'auth.email_label'|trans) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.password, 'auth.password_label'|trans) }}
                        {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.image, 'auth.image_label'|trans) }}
                        {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <button class="btn btn-primary w-100">{{ 'auth.register_submit'|trans }}</button>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

{% endblock %}
